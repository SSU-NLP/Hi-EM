# OpenAI-compatible LLM 자격증명 (memory/project_llm_backend.md / context/06-decision-log.md "2026-04-25 Phase 3-1")
#
# 사용법:
#   cp .env.example .env
#   # → .env에 본인 키 채우기 (.env는 .gitignored)
#   # → entry point 스크립트(scripts/smoke_test_*, Phase 4 평가 등)가
#   #   from dotenv import load_dotenv; load_dotenv() 로 자동 로드

# OpenRouter 사용 시 (https://openrouter.ai/keys)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# vLLM 로컬 사용 시 — 위 두 줄 주석 처리하고 아래 활성화
# OPENAI_API_KEY=dummy
# OPENAI_BASE_URL=http://localhost:8000/v1

# W&B 로깅 (Phase 4 평가). 키 없으면 wandb는 no-op (스크립트 정상 동작).
# WANDB_API_KEY=
# WANDB_PROJECT=hi-em-phase4   (기본값 — 스크립트 인자로도 override 가능)

# Hi-EM 스크립트 default override (모두 선택, CLI 인자가 우선).
# scripts/run_longmemeval.py + scripts/judge_longmemeval.py가 .env 자동 로드.
# HIEM_MODEL=Qwen/Qwen3-8B
# HIEM_JUDGE_MODEL=Qwen/Qwen3-8B          # 미설정 시 HIEM_MODEL 사용
# HIEM_RUN_MAX_TOKENS=800                  # hypothesis 생성 (Qwen <think> + answer)
# HIEM_JUDGE_MAX_TOKENS=256                # judge 응답 (think + yes/no)
# HIEM_TEMPERATURE=0.7
# HIEM_DEVICE=                             # 미설정 = auto (cuda → mps → cpu)
                                           # 명시: cuda / mps (Apple Silicon) / cpu
                                           # 같은 bge 가중치 — 환경별 결과 일관 유지
# HIEM_NO_THINKING=true                    # Qwen3 reasoning model에서 <think> 블록 차단
                                           # (chat_template_kwargs.enable_thinking=False)
